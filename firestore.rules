rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      // Users can write their own doc; admins can write any user doc (for role promotion)
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    match /friendships/{id} {
      allow read: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.users
        && request.auth.uid == request.resource.data.from
        && request.resource.data.status == "pending";
      allow update: if request.auth != null && request.auth.uid in resource.data.users;
      allow delete: if request.auth != null && request.auth.uid in resource.data.users;
    }

    match /sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.status == "active";
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.createdBy || isAdmin());
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joinedBy'])
        && request.resource.data.joinedBy.size() > resource.data.joinedBy.size()
        && request.resource.data.joinedBy[0:resource.data.joinedBy.size()] == resource.data.joinedBy;
    }

    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    match /discussions/{discussionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.createdBy || isAdmin());
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies'])
        && request.resource.data.replies.size() > resource.data.replies.size()
        && request.resource.data.replies[0:resource.data.replies.size()] == resource.data.replies;
    }

    match /activity/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow delete: if isAdmin();
    }

    match /analytics/{eventId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
    }

    match /groupInvites/{inviteId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromUid;
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
    }

    match /groups/{groupId} {
      allow read: if request.auth != null
        && (resource.data.visibility == "public" || request.auth.uid in resource.data.members);
      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.members || resource.data.visibility == "public");
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.createdBy || isAdmin());

      match /messages/{messageId} {
        allow read, create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow delete: if isAdmin();
      }
    }

  }
}
