rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // Any signed-in user can read profiles (needed for friend search + displaying names)
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /friendships/{id} {
      allow read: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.users
        && request.auth.uid == request.resource.data.from
        && request.resource.data.status == "pending";
      allow update: if request.auth != null && request.auth.uid in resource.data.users;
      allow delete: if request.auth != null && request.auth.uid in resource.data.users;
    }

    match /sessions/{sessionId} {
      // Any signed-in user can read active sessions
      allow read: if request.auth != null && resource.data.status == "active";

      // Any signed-in user can create a session
      allow create: if request.auth != null;

      // Only the creator can update (e.g. expire) or delete their session
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      // Any authenticated user can join a session (append to joinedBy only, no removals or edits)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joinedBy'])
        && request.resource.data.joinedBy.size() > resource.data.joinedBy.size()
        && request.resource.data.joinedBy[0:resource.data.joinedBy.size()] == resource.data.joinedBy;
    }

    match /courses/{courseId} {
      // Any signed-in user can read courses (needed for honor code checks)
      allow read: if request.auth != null;

      // Any signed-in user can create/update courses for now (no admin role yet)
      allow create, update: if request.auth != null;

      // Courses are never deleted from the client
      allow delete: if false;
    }

    match /discussions/{discussionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;

      // Only the creator can delete or fully update their discussion
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      // Any authenticated user can append a reply, but cannot edit or remove existing replies
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies'])
        && request.resource.data.replies.size() > resource.data.replies.size()
        && request.resource.data.replies[0:resource.data.replies.size()] == resource.data.replies;
    }

    match /groupInvites/{inviteId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromUid;
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
    }

    match /groups/{groupId} {
      // Public groups are readable by any signed-in user; private groups only by members
      allow read: if request.auth != null
        && (resource.data.visibility == "public" || request.auth.uid in resource.data.members);
      // Any auth user can create a group (creator adds themselves as first member)
      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;
      // Members can update (invite others, leave); anyone can join a public group
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.members || resource.data.visibility == "public");
      // Only creator can delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      match /messages/{messageId} {
        // Only group members can read/write messages
        allow read, create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }

  }
}
